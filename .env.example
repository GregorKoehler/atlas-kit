# Copy to ".env" at the repo root and fill in. NEVER commit the real .env.
# Everything with a sensible default is optional; the REQUIRED ones are marked.

# --- The vault (your knowledge base) -------------------------------------
# Absolute path on the box to your Atlas vault — a git checkout of your repo
# created from the llm-atlas template (https://github.com/GregorKoehler/llm-atlas).
# The dashboard reads Wiki/ + Tasks/ from here; agents commit back into it.  REQUIRED.
VAULT_PATH=/vault

# --- App-layer auth ------------------------------------------------------
# Shared bearer for every write/exec route. Generate a long random value:
#   openssl rand -hex 32
# In production Caddy injects it server-side so the browser never holds it.  REQUIRED.
DASHBOARD_BEARER_TOKEN=

# --- Express API ---------------------------------------------------------
API_PORT=3001                 # Express listens here (127.0.0.1 only; fronted by /api proxy)
API_HOST=127.0.0.1

# --- MCP server (the vault + agent control as a Claude connector) ---------
MCP_PORT=3002
MCP_BIND=127.0.0.1
# Cloudflare Access (Managed OAuth) for the REMOTE MCP connector. Leave BOTH
# blank for local-only use (the JWT check is then a no-op). Fill once the
# Access app exists (see docs/SETUP.md):
CF_ACCESS_TEAM_DOMAIN=        # e.g. yourteam.cloudflareaccess.com
CF_ACCESS_AUD=               # the Access application's AUD tag

# --- Box-local dev/knowledge agents (git worktree + tmux + claude CLI) ----
# WORKSPACE_DIR   default repo path for a box-local dev-agent repo whose entry
#                 in agent-local-repos.json omits `path` (default /workspace).
# AGENT_LOCAL_DIR state dir for worktrees, registry, audit log (default ~/.atlas-kit).
# WORKSPACE_DIR=/workspace
# AGENT_LOCAL_DIR=/root/.atlas-kit
# AGENT_LOCAL_MAX_CONCURRENT=4          # cap live box-local agents (RAM guard)
# AGENT_TITLE_MODEL=claude-haiku-4-5    # tiny claude -p that titles a new agent

# --- Vault commit identity (agents + Kanban commits) ---------------------
# The name/email stamped on commits the API makes to your vault.
ATLAS_AUTHOR_NAME=Atlas Kit
ATLAS_AUTHOR_EMAIL=atlas-kit@localhost
ATLAS_BRANCH=main

# --- Remote dev agents via a workstation bridge (optional) ----------------
# Leave AGENT_BRIDGE_URL blank and the remote-spawn path just shows "offline".
# The bridge runs on another machine on your Tailscale tailnet (see agent-bridge/).
AGENT_BRIDGE_URL=            # e.g. http://100.x.y.z:7878 (the workstation's tailnet IP)
AGENT_BRIDGE_TOKEN=         # MUST match BRIDGE_TOKEN in agent-bridge/bridge.env
AGENT_WORKSTATION_LABEL=workstation
AGENT_BRIDGE_REPOS=         # comma list of repo keys this bridge advertises as spawnable
